{
  "version": 2,

  "cleanUrls": true,

  "trailingSlash": false,

  "headers": [

    {
      "source": "/assets/(.*)",

      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },

    {
      "source": "/vynile/assets/(.*)",

      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },

    {
      "source": "/(.*).(mp3|mp4|jpg|jpeg|png|webp|gif|svg|ico|woff|woff2)",

      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }

  ]
}